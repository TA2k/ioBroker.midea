{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compileOnSave": true,
    "compilerOptions": {
        "noEmit": true,
        "allowJs": true,
        "checkJs": true,
        "resolveJsonModule": true,
        "noImplicitAny": false,
        "useUnknownInCatchVariables": false,
        "outDir": "./build/"
    },
    "include": [
        "**/*.js",
        "**/*.d.ts",
        "**/*.json"
    ],
    "exclude": [
        "node_modules/**",
        "admin/**"
    ]
}
