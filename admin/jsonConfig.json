{
  "type": "panel",
  "i18n": true,
  "items": {
    "cloudApp": {
      "type": "select",
      "label": "cloudApp",
      "help": "cloudAppHelp",
      "newLine": true,
      "options": [
        { "label": "MSmartHome", "value": "msmarthome" },
        { "label": "NetHome Plus", "value": "nethome" },
        { "label": "Midea Air", "value": "midea-air" },
        { "label": "Ariston Clima", "value": "ariston-clima" }
      ],
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "user": {
      "type": "text",
      "label": "user",
      "help": "userHelp",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "password": {
      "type": "password",
      "label": "password",
      "help": "passwordHelp",
      "repeat": false,
      "visible": true,
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "interval": {
      "type": "number",
      "label": "interval",
      "help": "intervalHelp",
      "min": 5,
      "max": 3600,
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "_refreshDevices": {
      "type": "sendTo",
      "label": "refreshDevices",
      "command": "refreshDeviceList",
      "useNative": true,
      "newLine": true,
      "variant": "contained",
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 4,
      "xl": 4
    },
    "deviceList": {
      "type": "table",
      "label": "deviceList",
      "help": "deviceListHelp",
      "newLine": true,
      "items": [
        {
          "type": "text",
          "attr": "id",
          "title": "deviceListId",
          "width": "30%",
          "readOnly": true
        },
        {
          "type": "text",
          "attr": "name",
          "title": "deviceListName",
          "width": "35%",
          "readOnly": true
        },
        {
          "type": "text",
          "attr": "host",
          "title": "deviceListHost",
          "width": "35%"
        }
      ],
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12
    }
  }
}
